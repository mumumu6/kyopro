{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "label": "コンパイルのみ（デバッグ）",
      "command": "mise",
      "args": ["run", "cpp-build", "${file}"],
      "options": { "cwd": "${fileDirname}" },
      "problemMatcher": ["$gcc"],
      "group": { "kind": "build", "isDefault": true },
      "detail": "デバッグ用に必要時のみコンパイル（更新なしなら skip）"
    },
    {
      "label": "実行のみ",
      "type": "shell",
      "command": "bash",
      "args": ["-lc", "\"${fileDirname}/out/${fileBasenameNoExtension}\""],
      "options": { "cwd": "${fileDirname}" },
      "problemMatcher": [],
      "detail": "out/ の実行ファイルをそのまま実行（コンパイルはしない）",
      "group": { "kind": "build", "isDefault": true }
    },
    {
      "label": "input.txtを読み込み実行",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "\"${fileDirname}/out/${fileBasenameNoExtension}\" < \"${fileDirname}/input.txt\""
      ],
      "options": { "cwd": "${fileDirname}" },
      "problemMatcher": [],
      "detail": "input.txt から読み込んで実行（コンパイルはしない）",
      "group": { "kind": "build", "isDefault": true }
    },
    {
      "label": "コンパイルしてinput.txtを読み込み実行",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "\"${fileDirname}/out/${fileBasenameNoExtension}\" < \"${fileDirname}/input.txt\""
      ],
      "options": { "cwd": "${fileDirname}" },
      "dependsOn": ["コンパイルのみ（デバッグ）"],
      "problemMatcher": [],
      "detail": "コンパイルしてから input.txt を読み込んで実行",
      "group": { "kind": "build", "isDefault": true }
    },
    {
      "label": "コンパイルして実行",
      "type": "shell",
      "command": "mise",
      "args": ["run", "cpp", "${file}"],
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "必要ならコンパイルして実行（mise）"
    }
  ]
}
